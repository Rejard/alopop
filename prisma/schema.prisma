generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  inviteCode    String?  @unique // Phase 12: 6자리 영문대문자+숫자 초대 코드
  googleId      String?  @unique // 신규 구글 소셜로그인 ID
  email         String?  @unique // 신규 구글 소셜로그인 Email
  username      String
  avatar_url    String?
  statusMessage String? // 유저의 한 줄 상태 메시지 (Phase 9 추가)
  walletBalance Int      @default(10000) // 가입 축하금
  isAi          Boolean  @default(false) // Phase 13: AI 유저 여부
  aiOwnerId     String?  // Phase 13: AI를 창조한 주인의 ID
  aiPrompt      String?  // Phase 13: 이 AI의 성격/페르소나 시스템 프롬프트
  isAdmin       Boolean  @default(false) // 관리자 권한 여부
  isAgent       Boolean  @default(false) // 원격 PC 제어 에이전트 여부
  agentToken    String?  @unique // 원격 PC 클라이언트 접속용 토큰
  agentPath     String?  // 원격 PC 작업 기준 경로 (파워쉘 cd 명령용)
  
  // AI 연동용 API Key (Sponsor 모드 - 평문 저장)
  openaiKey     String?
  geminiKey     String?
  anthropicKey  String?
  createdAt     DateTime @default(now())

  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  roomMembers          RoomMember[]

  // 친구 관계 (내가 추가한 사람, 나를 추가한 사람)
  friendsAdded Friendship[] @relation("UserAdded")
  addedBy      Friendship[] @relation("UserAddedBy")

  // 기기별 푸시 구독 정보
  pushSubscriptions PushSubscription[] @relation("UserPushSubscriptions")
  // 보상 수령 이력
  eventRewards UserEventReward[]
  eventUsages  UserEventUsage[]
  
  // 오프라인 메시지
  offlineMessages OfflineMessage[] @relation("UserOfflineMessages")
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Int
  reason    String?
  createdAt DateTime @default(now())

  senderId String
  sender   User   @relation("SentTransactions", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedTransactions", fields: [receiverId], references: [id])
}

model Room {
  id        String   @id @default(uuid())
  name      String? // 그룹명 (없으면 1:1)
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())

  sponsorMode   Boolean  @default(false) // 개별 방장 스폰서 기능 활성화 여부
  sponsorModel  String?  // 방장이 스폰서용으로 선택한 개별 방 AI 모델명
  sponsorPrice  Int      @default(0)     // 개별 방 1회 팩트체크당 과금 금액 (코인)

  members RoomMember[]
}

model RoomMember {
  id         String   @id @default(uuid())
  joinedAt   DateTime @default(now())
  isHost     Boolean  @default(false) // 최초 생성자(방장) 여부
  lastReadAt DateTime @default(now()) // 마지막으로 해당 방에서 메시지를 읽은(방 접속/메시지 수신) 시각
  isHidden   Boolean  @default(false) // 1:1 방 나가기 시 삭제 대신 숨김 처리용

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId]) // 한 방에 같은 유저가 중복 참석 방지
}

// 친구 관계 모델
model Friendship {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // 친구의 상태 (ACTIVE: 기본 친구, HIDDEN: 숨김, BLOCKED: 차단)
  status String @default("ACTIVE")

  // 주체 (친구를 추가/숨김/차단한 사람)
  userId String
  user   User   @relation("UserAdded", fields: [userId], references: [id], onDelete: Cascade)

  // 대상 (추가/숨김/차단 당한 사람)
  friendId String
  friend   User   @relation("UserAddedBy", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId]) // 한 방향의 관계는 유일해야 함
}

// 웹 푸시 알림 구독 정보 모델
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation("UserPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------------------- //
// [Phase 14] 관리자 전용 모델 (Admin Features)
// -------------------------------------------------------------------------------- //

// 시스템 전반적인 설정(가입 이벤트 명, 보상금 규모 등)
model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique // 설정의 고유 식별자 (예: "WELCOME_BONUS", "MAINTENANCE_MODE")
  value     String           // 값 (JSON string 형태로 저장 후 파싱 권장)
  updatedAt DateTime @default(now()) @updatedAt
}

// 전체 공지사항 (접속 시 노출할 팝업이나 상단바용)
model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  durationMs  Int      @default(4000)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 진행 중인 이벤트 (출석 타이머, 신모델 출시 이벤트 등)
model Event {
  id              String   @id @default(uuid())
  title           String
  description     String?
  reward          Int      @default(0) // 지급할 코인 량 등
  isActive        Boolean  @default(true)
  eventType       String   @default("REWARD") // "REWARD" 또는 "FREE_AI"
  rewardFrequency String   @default("ONCE") // "ONCE" 또는 "DAILY"
  
  // 무료 AI 이벤트 전용 필드
  aiProvider      String?
  aiModel         String?
  eventApiKey     String?  
  dailyLimit      Int?     @default(30) // 일일 사용 한도 (0이면 무제한)

  startDate       DateTime @default(now())
  endDate         DateTime? // null이면 무기한
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rewardLogs      UserEventReward[]
  usageLogs       UserEventUsage[]
}

// 개별 사용자의 이벤트 보상 수령 이력 (매일 1회 또는 1회성 중복 지급 방지)
model UserEventReward {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, eventId])
}

// 무료 AI 이벤트 일일 사용량 추적 모델
model UserEventUsage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  usageDate   String   // "YYYY-MM-DD" 형태의 (KST 기준) 날짜
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, eventId, usageDate])
  @@index([userId, eventId])
}

// 오프라인 유저를 위한 임시 메시지 보관함 (메모리 누수 방지용)
model OfflineMessage {
  id          String   @id @default(uuid())
  receiverId  String
  receiver    User     @relation("UserOfflineMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  kind        String   @default("NOTICE")
  status      String   @default("PENDING")
  
  // JSON 문자열 형태로 메시지 객체 자체를 보관 (발신자, 내용, 타입 등 모두 포함)
  payload     String
  
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  deliveredAt DateTime?
  attemptCount Int     @default(0)
  
  @@index([receiverId])
  @@index([expiresAt])
}

// =============================================
// Pet365Care 관련 모델
// =============================================

// 동물병원 정보 (공공데이터 동기화)
model Hospital {
  id          String   @id @default(uuid())
  name        String
  address     String
  phone       String
  website     String?
  lat         Float    // 위도
  lng         Float    // 경도
  openHours   String?  // 진료시간 (예: "09:00-21:00")
  specialties String?  // 전문 분야 (콤마 구분)
  isEmergency Boolean  @default(false) // 24시간/응급 가능 여부
  createdAt   DateTime @default(now())

  @@index([lat, lng])
}

// Pet365Care AI 분석 로그
model Pet365ApiLog {
  id        String   @id @default(uuid())
  type      String   // 'AI_SUCCESS' | 'AI_FAIL' | 'AI_FALLBACK'
  endpoint  String   // '/api/pet365care/ai'
  detail    String?  // 에러 메시지 (PII 제외)
  model     String?  // 사용된 AI 모델명
  userId    String?  // 요청한 유저 ID
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// Pet365Care 데이터 백업 (게임 세이브 슬롯 방식, 유저당 1개)
model Pet365Backup {
  id        String   @id @default(uuid())
  userId    String   @unique  // 유저당 1개 슬롯
  data      String   // LZ-string 압축된 JSON
  size      Int      // 원본 바이트 수
  petCount  Int      // 펫 수 (UI 표시용)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Pet365Care 소셜 커뮤니티
model PetPost {
  id           String   @id @default(uuid())
  authorId     String
  content      String
  images       String?        // JSON 배열: ["/uploads/pet_social_xxx.jpg", ...]
  category     String   @default("daily")  // daily, walk, health, funny
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comments     PetComment[]
  likes        PetLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
}

model PetComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post      PetPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PetLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      PetPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
